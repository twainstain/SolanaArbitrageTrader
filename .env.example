# ============================================================
# SolanaTrader — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env — it's in .gitignore.
# ============================================================

# --- Bot Defaults (override with CLI flags) ---
BOT_CONFIG=config/example_config.json
BOT_ITERATIONS=10
BOT_DRY_RUN=true
BOT_NO_SLEEP=false
BOT_MODE=simulated          # simulated | jupiter

# --- Solana RPC Endpoints ---
# Use Helius / Triton / QuickNode for production.  Public mainnet-beta
# is fine for light Phase-1 scanning but gets rate-limited fast.
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# SOLANA_RPC_URL_2=https://rpc.ankr.com/solana
# HELIUS_API_KEY=your_helius_key

# --- Jupiter Quote API ---
# Defaults to the free tier public endpoint. Override for paid/self-hosted.
# JUPITER_API_URL=https://lite-api.jup.ag/swap/v1

# --- Database ---
# Prod: Postgres in the same docker-compose (hostname "postgres", internal).
# Local dev: leave DATABASE_URL empty → SQLite at data/solana_arb.db.
#
# For production, DO NOT copy these values — run `scripts/phase_a_host.sh`
# on the EC2 host to generate a strong password and write a clean block.
# Left unset here so docker-compose's ${POSTGRES_PASSWORD:?...} guard
# fails loudly if .env was copied literally from this template.
POSTGRES_DB=solana_arb
POSTGRES_USER=solana
# POSTGRES_PASSWORD=                # set by scripts/setup_env.py
# DATABASE_URL=postgresql://solana:<pw>@postgres:5432/solana_arb

# --- S3 backups (production only; needs EC2 IAM role with s3:PutObject) ---
# BACKUP_S3_BUCKET=yeda-ai-solana-backups
# BACKUP_S3_PREFIX=daily
# BACKUP_RETENTION_DAYS=30
# AWS_REGION=us-east-1

# --- Wallet (Phase 3+: execution) ---
# SOLANA_WALLET_PUBKEY=YourBase58Pubkey
# Never commit the private key; use a hardware wallet or KMS.
# SOLANA_WALLET_KEYPAIR_PATH=/secure/path/to/keypair.json

# --- Dashboard Auth (HTTP Basic — if/when API is rebuilt) ---
# DASHBOARD_USER=admin
# DASHBOARD_PASS=change_me

# --- Telegram Alerts ---
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=987654321

# --- Discord Alerts ---
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Gmail Alerts ---
# GMAIL_ADDRESS=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# GMAIL_RECIPIENT=you@gmail.com
