# ============================================================
# SolanaTrader — Local-Dev / CI Defaults
# ============================================================
# This file IS committed.  Never put real secrets here.
#
# Loaded by scripts/run_local.sh when .env is missing, so a fresh
# clone can run the scanner immediately:
#
#   git clone ... && cd SolanaArbitrageTrader
#   ./scripts/run_local.sh --sim
#
# For real Jupiter scans, copy this to .env and add an RPC key:
#   cp .env.test .env
#   echo "SOLANA_RPC_URL=https://..." >> .env
# ============================================================

# --- Bot defaults ---
BOT_CONFIG=config/example_config.json
BOT_ITERATIONS=50
BOT_DRY_RUN=true
BOT_NO_SLEEP=false
BOT_MODE=simulated            # simulated | jupiter

# --- Database ---
# Empty → local SQLite at data/solana_arb.db (safe; never touches prod)
DATABASE_URL=

# --- Solana RPC (only needed for --jupiter / Phase 3+ execution) ---
# DO NOT put real keys here — .env.test IS committed.  Put them in .env.
# The public mainnet endpoint below is fine for light sim/smoke testing.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# HELIUS_API_KEY=

# --- Jupiter quote API ---
JUPITER_API_URL=https://lite-api.jup.ag/swap/v1

# --- Wallet (Phase 3+ only; scanner doesn't need this) ---
# SOLANA_WALLET_PUBKEY=
# SOLANA_WALLET_KEYPAIR_PATH=

# --- Dashboard (when the API is rebuilt in Phase 4) ---
DASHBOARD_USER=admin
DASHBOARD_PASS=test

# --- Alerts (disabled locally) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=
# GMAIL_ADDRESS=
# GMAIL_APP_PASSWORD=
# GMAIL_RECIPIENT=
