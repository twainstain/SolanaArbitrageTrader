# ============================================================
# Arbitrage Bot Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# -- API Keys --
THEGRAPH_API_KEY=           # Free at https://thegraph.com/studio/apikeys/

# -- RPC Endpoints (optional, overrides free public defaults) --
# RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# -- On-Chain Executor (Phase 3 — real trading) --
# EXECUTOR_PRIVATE_KEY=0x...  # Wallet private key (NEVER commit this!)
# EXECUTOR_CONTRACT=0x...     # Deployed FlashArbExecutor contract address

# -- Bot Defaults --
BOT_CONFIG=config/example_config.json
BOT_ITERATIONS=10
BOT_DRY_RUN=false
BOT_NO_SLEEP=false
BOT_MODE=simulated          # simulated | live | onchain | subgraph
